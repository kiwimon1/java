package jump2java;

import java.util.Scanner;

public class random {
    public static void main(String[] args){

        Scanner sc = new Scanner(System.in); 
        
        System.out.print("Enter a number: ");
        int num = sc.nextInt();
        
        int count = 0;
        while(num > 0) {
            num = num / 10;
            count++;
        }
        
        System.out.println("Number of digits: " + count);
        sc.close(); 
    }
}
